# Configuracion general de la aplicacion.
APP_NAME=Novitec DWH
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
API_AUTH_ENABLED=false
API_AUTH_TOKEN=
LOG_DIRECTORY=logs

# Configuracion de extraccion por lotes.
ETL_CHUNK_SIZE=1000
ETL_RAW_BASE_PATH=data/raw
ETL_FINANCIAL_EXTRACTION_ID=
ETL_OPERATIONAL_EXTRACTION_ID=
ETL_TECHNICAL_EXTRACTION_ID=
ETL_INVENTORY_EXTRACTION_ID=
ETL_CRM_EXTRACTION_ID=
ETL_WARRANTY_EXTRACTION_ID=
ETL_ORGANIZATIONAL_EXTRACTION_ID=

# Conexion a MySQL origen transaccional.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=railway
MYSQL_USER=root
MYSQL_PASSWORD=secret

# Conexion a PostgreSQL destino analitico mediante connection string.
POSTGRES_DSN=postgresql://usuario:password@localhost:5432/novitec_dwh?sslmode=require
POSTGRES_FINANCIAL_STAGING_SCHEMA=stg_financial
POSTGRES_FINANCIAL_MART_SCHEMA=dwh_financial
POSTGRES_OPERATIONAL_STAGING_SCHEMA=stg_operational
POSTGRES_OPERATIONAL_MART_SCHEMA=dwh_operational
POSTGRES_TECHNICAL_STAGING_SCHEMA=stg_technical
POSTGRES_TECHNICAL_MART_SCHEMA=dwh_technical
POSTGRES_INVENTORY_STAGING_SCHEMA=stg_inventory
POSTGRES_INVENTORY_MART_SCHEMA=dwh_inventory
POSTGRES_CRM_STAGING_SCHEMA=stg_crm
POSTGRES_CRM_MART_SCHEMA=dwh_crm
POSTGRES_WARRANTY_STAGING_SCHEMA=stg_warranty
POSTGRES_WARRANTY_MART_SCHEMA=dwh_warranty
POSTGRES_ORGANIZATIONAL_STAGING_SCHEMA=stg_organizational
POSTGRES_ORGANIZATIONAL_MART_SCHEMA=dwh_organizational
POSTGRES_SEMANTIC_SCHEMA=sem_power_bi
